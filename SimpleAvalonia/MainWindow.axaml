<Window x:Class="SimpleAvalonia.MainWindow"        xmlns="https://github.com/avaloniaui"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        WindowStartupLocation="CenterScreen"        MinWidth="400" MinHeight="400"        Width="400" Height="400"        Title="Пример">    <DockPanel>        <Menu DockPanel.Dock="Top">            <MenuItem Header="Файл">                <MenuItem Header="Выход" Click="OnExitClick" />            </MenuItem>        </Menu>        <DockPanel Margin="10">            <StackPanel DockPanel.Dock="Bottom"                        HorizontalAlignment="Right"                        Margin="0,10,0,0"                        Orientation="Horizontal">                <Button Click="OnAddClick"                        Content="Добавить"                        Padding="16,4,16,4" />                <Button Click="OnRemoveClick"                        Content="Удалить"                        IsEnabled="False"                        Margin="10,0,0,0"                        Name="RemoveButton"                        Padding="16,4,16,4" />            </StackPanel>            <ListBox Name="IntegerListBox"                     SelectionChanged="OnSelectionChanged" />        </DockPanel>    </DockPanel></Window>